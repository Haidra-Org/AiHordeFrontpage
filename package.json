{
  "name": "ai-horde-website",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "serve:ssr:AiHordeWebsite": "node dist/ai-horde-website/server/server.mjs",
    "deploy": "ng build && npx wrangler deploy",
    "lint": "ng lint",
    "lint:css": "node scripts/lint-css-duplicates.mjs",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\"",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/build": "^21.2.7",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-server": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@angular/ssr": "^21.2.7",
    "@jsverse/transloco": "8.2.1",
    "@tailwindcss/postcss": "^4.2.2",
    "express": "^5.2.1",
    "marked": "^17.0.6",
    "postcss": "^8.5.9",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.4",
    "@analogjs/vitest-angular": "^2.4.4",
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.15",
    "angular-cli-ghpages": "^3.0.2",
    "angular-eslint": "^21.3.1",
    "eslint-plugin-rxjs-x": "^1.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.html": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
